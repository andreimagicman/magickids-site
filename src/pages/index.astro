    .why-numbers { grid-template-columns: 1fr; }
    .num-card { padding: 24px 18px; }
    .num-card .big-num { font-size: 2.6rem; }
  }
</style>

<script>
  // ═══════════════════════════════════════════════
  // 🪄 ANIMAȚIA DE VRAJĂ
  // ═══════════════════════════════════════════════
  function castMagicSpell(triggerLogoTremor = false) {
    const heroVisual = document.querySelector<HTMLElement>('.hero-visual');
    const logoWrap = document.querySelector<HTMLElement>('.hero-logo-wrap');
    const sparkles = document.querySelectorAll<HTMLElement>('.sparkle');
    const glowLeft = document.getElementById('wandGlowLeft');
    const glowRight = document.getElementById('wandGlowRight');

    if (!heroVisual || !logoWrap || sparkles.length === 0 || !glowLeft || !glowRight) return;

    if (triggerLogoTremor) {
      logoWrap.classList.remove('casting');
      void logoWrap.offsetWidth;
      logoWrap.classList.add('casting');
      setTimeout(() => logoWrap.classList.remove('casting'), 1500);
    }

    const visualRect = heroVisual.getBoundingClientRect();
    const logoRect = logoWrap.getBoundingClientRect();
    const logoOffsetX = logoRect.left - visualRect.left;
    const logoOffsetY = logoRect.top - visualRect.top;
    const wandLeft = {
      x: logoOffsetX + logoRect.width * 0.22,
      y: logoOffsetY + logoRect.height * 0.70
    };
    const wandRight = {
      x: logoOffsetX + logoRect.width * 0.78,
      y: logoOffsetY + logoRect.height * 0.70
    };

    glowLeft.style.left = wandLeft.x + 'px';
    glowLeft.style.top = wandLeft.y + 'px';
    glowRight.style.left = wandRight.x + 'px';
    glowRight.style.top = wandRight.y + 'px';

    sparkles.forEach(s => { s.classList.remove('cast', 'twinkling'); });
    glowLeft.classList.remove('active');
    glowRight.classList.remove('active');

    void heroVisual.offsetWidth;

    sparkles.forEach((sparkle, i) => {
      const sparkleRect = sparkle.getBoundingClientRect();
      const sparkleX = sparkleRect.left - visualRect.left + sparkleRect.width / 2;
      const sparkleY = sparkleRect.top - visualRect.top + sparkleRect.height / 2;
      const distLeft = Math.hypot(sparkleX - wandLeft.x, sparkleY - wandLeft.y);
      const distRight = Math.hypot(sparkleX - wandRight.x, sparkleY - wandRight.y);
      const wand = distLeft < distRight ? wandLeft : wandRight;
      const dx = wand.x - sparkleX;
      const dy = wand.y - sparkleY;

      sparkle.style.setProperty('--dx', dx + 'px');
      sparkle.style.setProperty('--dy', dy + 'px');
      const baseDelay = 0.3 + (i * 0.04);
      const randomJitter = (Math.random() - 0.5) * 0.1;
      sparkle.style.animationDelay = (baseDelay + randomJitter) + 's';
      sparkle.classList.add('cast');

      const animDuration = 2.4;
      setTimeout(() => {
        sparkle.classList.remove('cast');
        sparkle.classList.add('twinkling');
        sparkle.style.animationDelay = (Math.random() * 2) + 's';
      }, (baseDelay + randomJitter + animDuration) * 1000);
    });

    setTimeout(() => {
      glowLeft.classList.add('active');
      glowRight.classList.add('active');
    }, 250);
  }

  // Lansare la încărcare
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => castMagicSpell(true), 1500);
    });
  } else {
    setTimeout(() => castMagicSpell(true), 1500);
  }

  // Fade-up on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.opacity = '1';
        (e.target as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.why-feat, .num-card, .explore-card').forEach(el => {
    const elem = el as HTMLElement;
    elem.style.opacity = '0';
    elem.style.transform = 'translateY(24px)';
    elem.style.transition = 'opacity .6s ease, transform .6s ease';
    observer.observe(el);
  });
</script>
