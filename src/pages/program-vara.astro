---
import BaseLayout from '../layouts/BaseLayout.astro';
import SummerLeadModal from '../components/SummerLeadModal.astro';

const breadcrumbs = [
  { name: 'Acasă', url: '/' },
  { name: 'Program de vară', url: '/program-vara/' },
];
---

<BaseLayout
  title="Program de vară 2026 — Magic Kids Afterschool Novaci"
  description="Program de vară pentru copii la Magic Kids Novaci, 1 – 31 iulie 2026. Orar 08:00–16:00, activități recreative fără teme. Variante: abonament pe toată luna iulie sau tarif zilnic (4, 5 sau 8 ore, cu sau fără masă). Primește oferta personalizată."
  pageName="Program de vară"
  breadcrumbs={breadcrumbs}>

  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Cale de navigare">
        <a href="/">Acasă</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Program de vară</span>
      </nav>
      <span class="section-label">🌞 Vara 2026</span>
      <h1>O vară plină de joacă și prieteni</h1>
      <p class="page-hero-desc">Cât timp tu ești la serviciu, copilul tău petrece zilele de vară într-un mediu sigur și supravegheat — cu activități recreative, jocuri și voie bună. Fără teme, doar distracție.</p>
    </div>
  </section>

  <!-- SUMMER PROGRAM CARD -->
  <section id="program-vara">
    <div class="container">
      <article class="summer-card">
        <div class="summer-card-glow" aria-hidden="true"></div>
        <div class="summer-card-content">
          <span class="summer-card-tag">🌞 Înscrieri deschise</span>
          <h2 class="summer-card-title">Program de Vară</h2>
          <p class="summer-card-lead">Alege varianta potrivită pentru familia ta: abonament pe toată luna iulie cu program complet sau tarif zilnic flexibil, cu sau fără masă. Spune-ne ce te interesează și îți trimitem oferta personalizată.</p>

          <div class="summer-features">
            <div class="summer-feature">
              <span class="summer-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </span>
              <div><strong>Orar</strong><span>08:00 – 16:00</span></div>
            </div>
            <div class="summer-feature">
              <span class="summer-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
              </span>
              <div><strong>Perioada</strong><span>1 – 31 iulie 2026</span></div>
            </div>
            <div class="summer-feature">
              <span class="summer-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              </span>
              <div><strong>Activități recreative</strong><span>Fără teme școlare</span></div>
            </div>
          </div>

          <button type="button" class="btn btn-primary summer-card-btn" data-open-summer-modal>Primește oferta personalizată →</button>
        </div>
      </article>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section id="vara-activitati">
    <div class="container">
      <div class="vara-header">
        <span class="section-label">Cum arată o zi de vară</span>
        <h2 class="section-title">Zile pline, copii fericiți</h2>
        <p class="section-sub">Un amestec echilibrat de joacă, mișcare și creativitate — într-un colectiv mic, cu supraveghere atentă.</p>
      </div>
      <div class="vara-grid">
        <article class="vara-card">
          <div class="vara-icon" aria-hidden="true">🎨</div>
          <h3>Ateliere creative</h3>
          <p>Pictură, desen, lucru manual și mici proiecte care le pun imaginația la treabă.</p>
        </article>
        <article class="vara-card">
          <div class="vara-icon" aria-hidden="true">⚽</div>
          <h3>Joacă și mișcare</h3>
          <p>Jocuri în aer liber, activități sportive și energie consumată sănătos.</p>
        </article>
        <article class="vara-card">
          <div class="vara-icon" aria-hidden="true">📖</div>
          <h3>Povești și jocuri</h3>
          <p>Lectură relaxată, jocuri de societate și activități care dezvoltă atenția.</p>
        </article>
        <article class="vara-card">
          <div class="vara-icon" aria-hidden="true">🍲</div>
          <h3>Masă caldă (opțional)</h3>
          <p>În funcție de varianta aleasă, copilul primește o masă caldă la prânz.</p>
        </article>
      </div>
      <div class="vara-cta-row">
        <button type="button" class="btn btn-primary" data-open-summer-modal>Primește oferta personalizată →</button>
      </div>
    </div>
  </section>

  <SummerLeadModal />
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    padding: 130px 0 60px;
    background:
      radial-gradient(ellipse 80% 60% at 70% 40%, rgba(63,189,174,.20) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 10% 80%, rgba(43,179,224,.14) 0%, transparent 60%),
      var(--cream);
    text-align: center;
  }
  .page-hero h1 {
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3.4rem);
    margin-bottom: 16px;
  }
  .page-hero-desc {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .breadcrumbs {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 16px;
    font-size: .85rem;
    color: var(--muted);
  }
  .breadcrumbs a { color: var(--magenta); text-decoration: none; }
  .breadcrumbs a:hover { text-decoration: underline; }

  /* SUMMER CARD */
  #program-vara { padding: 40px 0 80px; }
  .summer-card {
    position: relative;
    max-width: 920px;
    margin: 0 auto;
    border-radius: 32px;
    overflow: hidden;
    background: linear-gradient(135deg, var(--teal), var(--blue));
    box-shadow: var(--shadow-lg);
  }
  .summer-card-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 85% 15%, rgba(255,217,61,.35) 0%, transparent 45%),
      radial-gradient(circle at 10% 90%, rgba(255,255,255,.25) 0%, transparent 50%);
    z-index: 0;
  }
  .summer-card-content {
    position: relative;
    z-index: 1;
    padding: 56px 48px;
    text-align: center;
    color: var(--white);
  }
  .summer-card-tag {
    display: inline-block;
    background: rgba(255,255,255,.22);
    color: var(--white);
    font-family: 'Baloo 2', sans-serif;
    font-weight: 700;
    font-size: .82rem;
    letter-spacing: .04em;
    padding: 6px 16px;
    border-radius: 50px;
    margin-bottom: 16px;
    backdrop-filter: blur(4px);
  }
  .summer-card-title {
    font-family: 'Baloo 2', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4.5vw, 3rem);
    color: var(--white);
    margin-bottom: 16px;
  }
  .summer-card-lead {
    font-size: 1.08rem;
    line-height: 1.7;
    color: rgba(255,255,255,.92);
    max-width: 620px;
    margin: 0 auto 36px;
  }
  .summer-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 720px;
    margin: 0 auto 40px;
  }
  .summer-feature {
    background: rgba(255,255,255,.14);
    border: 1px solid rgba(255,255,255,.22);
    border-radius: 16px;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    backdrop-filter: blur(4px);
  }
  .summer-feature-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,.22);
    color: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .summer-feature-icon svg { width: 22px; height: 22px; }
  .summer-feature div { display: flex; flex-direction: column; gap: 3px; }
  .summer-feature strong {
    font-family: 'Baloo 2', sans-serif;
    font-size: .95rem;
    font-weight: 800;
    color: var(--white);
  }
  .summer-feature span {
    font-size: .85rem;
    color: rgba(255,255,255,.88);
    line-height: 1.4;
  }
  .summer-card-btn {
    font-size: 1.1rem;
    box-shadow: 0 10px 30px rgba(230,59,140,.4);
  }

  /* ACTIVITĂȚI */
  #vara-activitati { padding: 80px 0; background: var(--cream); }
  .vara-header { text-align: center; margin-bottom: 50px; }
  .vara-header .section-sub { margin: 0 auto; }
  .vara-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }
  .vara-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 32px 24px;
    box-shadow: var(--shadow);
    text-align: center;
    border-top: 5px solid var(--teal);
    transition: transform .25s, box-shadow .25s;
  }
  .vara-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }
  .vara-icon { font-size: 2.6rem; margin-bottom: 14px; }
  .vara-card h3 {
    font-family: 'Baloo 2', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--navy);
    margin-bottom: 10px;
  }
  .vara-card p {
    font-size: .88rem;
    color: var(--muted);
    line-height: 1.6;
  }
  .vara-cta-row { text-align: center; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .summer-features { grid-template-columns: 1fr; max-width: 380px; }
    .summer-card-content { padding: 44px 26px; }
    .vara-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .vara-grid { grid-template-columns: 1fr; }
  }
</style>
