      <nav class="footer-col" aria-label="Navigare în footer">
        <h4>Navigare</h4>
        <ul role="list">
          <li><a href="/">Acasă</a></li>
          <li><a href="/servicii/">Servicii</a></li>
          <li><a href="/program/">Program</a></li>
          <li><a href="/tarif/">Tarif</a></li>
