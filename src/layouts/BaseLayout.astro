---
import SEO from '../components/SEO.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

import type { BreadcrumbItem } from '../components/SchemaOrg.astro';

export interface Props {
  title: string;
  description: string;
  pageName?: string;
  pageType?: 'WebPage' | 'AboutPage' | 'ContactPage' | 'Service';
  breadcrumbs?: BreadcrumbItem[];
  serviceName?: string;
  serviceDescription?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description,
  pageName = title,
  pageType = 'WebPage',
  breadcrumbs = [],
  serviceName,
  serviceDescription,
  ogImage,
  ogType = 'website',
  noindex = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- Fonturi optimizate -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;700;800&family=Nunito:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;700;800&family=Nunito:wght@400;500;600;700&display=swap"
    />

    <SEO
      title={title}
      description={description}
      image={ogImage}
      ogType={ogType}
      noindex={noindex}
    />

    <SchemaOrg
      type={pageType}
      pageName={pageName}
      pageDescription={description}
      breadcrumbs={breadcrumbs}
      serviceName={serviceName}
      serviceDescription={serviceDescription}
    />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Sari la conținutul principal</a>

    <Nav />

    <main id="main">
      <slot />
    </main>

    <Footer />
  </body>
</html>
