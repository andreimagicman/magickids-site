---
import BaseLayout from '../layouts/BaseLayout.astro';

const description =
  'Afterschool privat din Novaci, Gorj pentru clasele 0-IV. Calitate, nu cantitate. Sprijin la teme, masă caldă, activități tematice (engleză, art & craft, dezvoltare personală) și meditații. 1.350 lei / an școlar.';
---

<BaseLayout
  title="Magic Kids Afterschool Novaci — Calitate, nu cantitate"
  description={description}
  pageName="Acasă">

  <!-- HERO -->
  <section id="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text">
          <div class="hero-badge fade-up">
            <span class="icon icon-md icon-yellow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.582a.5.5 0 0 1 0 .962L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
                <path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>
              </svg>
            </span>
            Locuri limitate pentru 2026–2027
          </div>

          <h1 class="fade-up delay-1">
            Unde copiii<br />tăi <em>strălucesc</em><br />în fiecare zi
          </h1>

          <p class="hero-desc fade-up delay-2">
            La Magic Kids credem în <strong>calitate, nu cantitate</strong>. Grupe mici, atenție individuală și un program echilibrat — temele făcute, masa caldă servită, copilul fericit.
          </p>

          <div class="hero-btns fade-up delay-3">
            <a href="/contact/#inscriere" class="btn btn-primary">Vreau un loc acum →</a>
            <a href="/servicii/" class="btn btn-outline">Descoperă programul</a>
          </div>

          <div class="hero-stats fade-up delay-4">
            <div class="stat-item">
              <span class="stat-num">2+</span>
              <span class="stat-label">Ani de activitate</span>
            </div>
            <div class="stat-item">
              <span class="stat-num">98%</span>
              <span class="stat-label">Părinți mulțumiți</span>
            </div>
            <div class="stat-item">
              <span class="stat-num">5</span>
              <span class="stat-label">Activități pe săptămână</span>
            </div>
          </div>
        </div>

        <div class="hero-visual">
          <span class="wand-glow wand-glow-left" id="wandGlowLeft" aria-hidden="true"></span>
          <span class="wand-glow wand-glow-right" id="wandGlowRight" aria-hidden="true"></span>

          <span class="sparkle sp-1" aria-hidden="true">✦</span>
          <span class="sparkle sp-2" aria-hidden="true">✧</span>
          <span class="sparkle sp-3" aria-hidden="true">✦</span>
          <span class="sparkle sp-4" aria-hidden="true">✧</span>
          <span class="sparkle sp-5" aria-hidden="true">✦</span>
          <span class="sparkle sp-6" aria-hidden="true">✦</span>
          <span class="sparkle sp-7" aria-hidden="true">✧</span>
          <span class="sparkle sp-8" aria-hidden="true">★</span>
          <span class="sparkle sp-9" aria-hidden="true">✦</span>
          <span class="sparkle sp-10" aria-hidden="true">✧</span>
          <span class="sparkle sp-11" aria-hidden="true">✦</span>
          <span class="sparkle sp-12" aria-hidden="true">★</span>
          <span class="sparkle sp-13" aria-hidden="true">✧</span>
          <span class="sparkle sp-14" aria-hidden="true">✦</span>
          <span class="sparkle sp-15" aria-hidden="true">★</span>

          <div class="floating-chip chip-1" aria-hidden="true">🎨 Creativitate</div>
          <div class="floating-chip chip-2" aria-hidden="true">📚 Teme făcute!</div>
          <div class="floating-chip chip-3" aria-hidden="true">🌍 Engleză</div>

          <div class="hero-logo-wrap">
            <img src="/logo.png" alt="Magic Kids Afterschool — logo cu trei copii vrăjitori" width="460" height="460" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section id="trust" aria-label="Ce oferim cu încredere">
    <div class="container">
      <div class="trust-inner">
        <div class="trust-item">
          <span class="icon icon-xl icon-yellow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg></span>
          2 ani de experiență
        </div>
        <div class="trust-item">
          <span class="icon icon-xl icon-magenta"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg></span>
          Educatori calificați
        </div>
        <div class="trust-item">
          <span class="icon icon-xl icon-blue"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg></span>
          Mediu sigur &amp; supravegheat
        </div>
        <div class="trust-item">
          <span class="icon icon-xl icon-orange"><svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
          Sute de copii fericiți
        </div>
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section id="de-ce-noi" aria-labelledby="why-title">
    <div class="container">
      <div class="why-grid">
        <div class="why-text">
          <span class="section-label">De ce Magic Kids?</span>
          <h2 id="why-title" class="section-title">Calitate, nu cantitate</h2>
          <p class="section-sub">La afterschool-ul nostru ne pasă mai mult de fiecare copil decât de numărul de copii. Asta înseamnă atenție reală, comunicare deschisă și rezultate care se văd.</p>
          <div class="why-features">
            <div class="why-feat">
              <div class="feat-icon" style="background:rgba(43,179,224,.18); color:var(--blue);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
              </div>
              <div><h3>Fiecare copil, văzut individual</h3><p>Grupe mici, atenție personalizată — copilul tău nu este un număr.</p></div>
            </div>
            <div class="why-feat">
              <div class="feat-icon" style="background:rgba(230,59,140,.15); color:var(--magenta);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
              </div>
              <div><h3>Comunicare transparentă cu părinții</h3><p>Suntem mereu disponibili. Veți ști în orice moment cum a decurs ziua copilului.</p></div>
            </div>
            <div class="why-feat">
              <div class="feat-icon" style="background:rgba(63,189,174,.18); color:var(--teal);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
              </div>
              <div><h3>Mediu sigur și prietenos</h3><p>Spațiu securizat, masă caldă zilnică și un climat în care copilul se simte ca acasă.</p></div>
            </div>
            <div class="why-feat">
              <div class="feat-icon" style="background:rgba(255,138,42,.18); color:var(--orange);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
              </div>
              <div><h3>Flexibilitate reală</h3><p>Afterschool complet, doar opționale sau meditații — alegi ce funcționează pentru familia ta.</p></div>
            </div>
          </div>
        </div>
        <div class="why-numbers">
          <div class="num-card"><div class="big-num">2+</div><p>Ani de experiență</p></div>
          <div class="num-card"><div class="big-num">5h</div><p>Program zilnic</p></div>
          <div class="num-card"><div class="big-num">5</div><p>Tipuri de programe</p></div>
          <div class="num-card"><div class="big-num">98%</div><p>Satisfacție părinți</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA preview catre alte pagini -->
  <section id="explore">
    <div class="container">
      <div class="explore-header">
        <span class="section-label">Explorează</span>
        <h2 class="section-title">Tot ce trebuie să știi</h2>
      </div>
      <div class="explore-grid">
        <a href="/servicii/" class="explore-card explore-card-services">
          <div class="explore-icon">📚</div>
          <h3>Cele 5 programe</h3>
          <p>Afterschool, activități tematice, meditații, doar engleză sau opționale.</p>
          <span class="explore-cta">Vezi toate →</span>
        </a>
        <a href="/program/" class="explore-card explore-card-schedule">
          <div class="explore-icon">🕛</div>
          <h3>Programul zilnic</h3>
          <p>Cum decurge o zi tipică la Magic Kids — de la 12:00 la 17:00.</p>
          <span class="explore-cta">Vezi orarul →</span>
        </a>
        <a href="/tarif/" class="explore-card explore-card-price">
          <div class="explore-icon">💛</div>
          <h3>1.350 lei / an</h3>
          <p>Un singur tarif. Totul inclus. Ofertă valabilă doar acest an.</p>
          <span class="explore-cta">Vezi detalii →</span>
        </a>
        <a href="/contact/" class="explore-card explore-card-contact">
          <div class="explore-icon">📞</div>
          <h3>Vino să ne cunoști</h3>
          <p>Vizita e gratuită. Te sunăm noi în maxim 24 de ore.</p>
          <span class="explore-cta">Contactează-ne →</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  #hero {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    padding: 130px 0 80px;
    background:
      radial-gradient(ellipse 80% 60% at 70% 40%, rgba(43,179,224,.18) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 10% 80%, rgba(230,59,140,.12) 0%, transparent 60%),
      var(--cream);
    position: relative;
    overflow: hidden;
  }
  #hero::before {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: var(--yellow);
    opacity: .13;
    top: -120px; right: -120px;
  }
  #hero::after {
    content: '';
    position: absolute;
    width: 320px; height: 320px;
    border-radius: 50%;
    background: var(--magenta);
    opacity: .08;
    bottom: -60px; left: -80px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--white);
    border: 1.5px solid var(--blue);
    border-radius: 50px;
    padding: 6px 16px;
    font-size: .85rem;
    font-weight: 700;
    color: var(--blue);
    margin-bottom: 24px;
    box-shadow: var(--shadow);
  }

  h1 {
    font-weight: 800;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    line-height: 1.1;
    margin-bottom: 24px;
  }
  h1 em {
    font-style: normal;
    color: var(--magenta);
    position: relative;
  }
  h1 em::after {
    content: '';
    position: absolute;
    bottom: 2px; left: 0; right: 0;
    height: 8px;
    background: var(--yellow);
    opacity: .5;
    z-index: -1;
    border-radius: 4px;
  }

  .hero-desc {
    font-size: 1.15rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 36px;
    max-width: 480px;
  }
  .hero-desc strong { color: var(--magenta); }

  .hero-btns {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .hero-stats { display: flex; gap: 32px; flex-wrap: wrap; }
  .stat-item { display: flex; flex-direction: column; }
  .stat-num {
    font-family: 'Baloo 2', sans-serif;
    font-weight: 800;
    font-size: 2rem;
    color: var(--navy);
    line-height: 1;
  }
  .stat-label { font-size: .82rem; color: var(--muted); font-weight: 600; }

  /* HERO LOGO + ANIMAȚIE */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 480px;
  }

  .hero-logo-wrap {
    position: relative;
    z-index: 2;
    width: 460px;
    max-width: 100%;
    filter: drop-shadow(0 20px 40px rgba(20,37,63,.18));
    cursor: pointer;
    /* Două animații paralele */
    animation:
      logo-entrance 1.4s ease-out 0s 1 forwards,
      logo-float-rotate 6s ease-in-out 1.4s infinite;
    transform-origin: center center;
  }
  .hero-logo-wrap img { width: 100%; height: auto; }

  @keyframes logo-entrance {
    0% { opacity: 0; transform: translateY(0) scale(0) rotate(-180deg); }
    100% { opacity: 1; transform: translateY(0) scale(1) rotate(0deg); }
  }

  @keyframes logo-float-rotate {
    0%,100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-8px) rotate(1.5deg); }
    50% { transform: translateY(-14px) rotate(0deg); }
    75% { transform: translateY(-8px) rotate(-1.5deg); }
  }

  /* Casting tremor (vraja) */
  .hero-logo-wrap.casting {
    animation: logo-magic-tremor .6s ease-out, logo-float-rotate 6s ease-in-out .6s infinite !important;
  }
  @keyframes logo-magic-tremor {
    0%   { transform: translate(0, 0) rotate(0deg) scale(1); }
    10%  { transform: translate(-3px, -2px) rotate(-2deg) scale(1.02); }
    20%  { transform: translate(3px, -1px) rotate(2deg) scale(1.04); }
    30%  { transform: translate(-2px, 2px) rotate(-1deg) scale(1.06); }
    40%  { transform: translate(2px, -3px) rotate(2deg) scale(1.07); }
    50%  { transform: translate(-3px, 1px) rotate(-2deg) scale(1.08); }
    60%  { transform: translate(2px, 2px) rotate(1deg) scale(1.06); }
    70%  { transform: translate(-1px, -2px) rotate(-1deg) scale(1.04); }
    80%  { transform: translate(1px, 1px) rotate(1deg) scale(1.02); }
    100% { transform: translate(0, 0) rotate(0deg) scale(1); }
  }

  /* Aura magică */
  .hero-logo-wrap::before {
    content: '';
    position: absolute;
    inset: -20px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,217,61,.4), rgba(230,59,140,.2) 40%, transparent 70%);
    opacity: 0;
    z-index: -1;
    pointer-events: none;
    animation: logo-aura-burst 1.4s ease-out .3s;
  }
  @keyframes logo-aura-burst {
    0%   { opacity: 0; transform: scale(.5); }
    40%  { opacity: 1; transform: scale(1.3); }
    100% { opacity: 0; transform: scale(2); }
  }

  /* SPARKLES */
  .sparkle {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    will-change: transform, opacity;
    opacity: 0;
  }
  .sparkle.cast {
    animation: cast-spell var(--cast-duration, 2.4s) cubic-bezier(.25, .85, .35, 1) forwards;
  }
  .sparkle.twinkling {
    animation: twinkle 3s ease-in-out infinite;
    opacity: .9;
  }

  .sp-1 { top: 8%;  left: 6%;  color: var(--yellow);  font-size: 1.5rem; }
  .sp-2 { top: 20%; right: 4%; color: var(--blue);    font-size: 1.2rem; }
  .sp-3 { bottom: 18%; left: 2%; color: var(--magenta); font-size: 1.3rem; }
  .sp-4 { bottom: 8%; right: 8%; color: var(--orange); font-size: 1.4rem; }
  .sp-5 { top: 50%; left: -2%; color: var(--teal);    font-size: 1.1rem; }
  .sp-6  { top: 12%; left: 30%; color: var(--magenta); font-size: .8rem;  }
  .sp-7  { top: 18%; right: 28%; color: var(--yellow); font-size: .9rem; }
  .sp-8  { top: 35%; left: 12%; color: var(--orange); font-size: .7rem;  }
  .sp-9  { top: 40%; right: 10%; color: var(--teal);  font-size: .85rem; }
  .sp-10 { top: 60%; left: 18%; color: var(--blue);   font-size: .75rem; }
  .sp-11 { top: 65%; right: 18%; color: var(--magenta); font-size: .9rem; }
  .sp-12 { top: 28%; left: 45%; color: var(--yellow); font-size: .8rem;  }
  .sp-13 { top: 78%; left: 48%; color: var(--orange); font-size: .7rem;  }
  .sp-14 { top: 5%;  right: 38%; color: var(--teal);  font-size: .85rem; }
  .sp-15 { bottom: 30%; right: 32%; color: var(--blue); font-size: .75rem; }

  @keyframes cast-spell {
    0% { opacity: 0; transform: translate(var(--dx, 0), var(--dy, 0)) scale(.1) rotate(-180deg); }
    20% { opacity: 1; transform: translate(calc(var(--dx, 0) * .7), calc(var(--dy, 0) * .7)) scale(.6) rotate(-90deg); }
    75% { opacity: 1; transform: translate(0, 0) scale(1.5) rotate(30deg); }
    100% { opacity: .9; transform: translate(0, 0) scale(1) rotate(0); }
  }

  @keyframes twinkle {
    0%,100% { opacity: .35; transform: scale(.9); }
    50%     { opacity: 1;   transform: scale(1.2); }
  }

  /* Glow baghete */
  .wand-glow {
    position: absolute;
    width: 80px; height: 80px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transform: translate(-50%, -50%);
  }
  .wand-glow-left {
    background: radial-gradient(circle, rgba(255,217,61,.65), rgba(230,59,140,.25) 50%, transparent 70%);
  }
  .wand-glow-right {
    background: radial-gradient(circle, rgba(43,179,224,.65), rgba(255,138,42,.25) 50%, transparent 70%);
  }
  .wand-glow.active {
    animation: wand-glow-anim 1.4s ease-out forwards;
  }
  @keyframes wand-glow-anim {
    0%   { opacity: 0; transform: translate(-50%, -50%) scale(.2); }
    30%  { opacity: 1; transform: translate(-50%, -50%) scale(1.3); }
    100% { opacity: 0; transform: translate(-50%, -50%) scale(2); }
  }

  /* Floating chips */
  .floating-chip {
    position: absolute;
    background: var(--white);
    border-radius: 16px;
    box-shadow: var(--shadow);
    padding: 10px 16px;
    font-weight: 700;
    font-size: .85rem;
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 3;
    animation: float-chip 3.5s ease-in-out infinite;
  }
  .chip-1 { top: 8%;  left: -20px; animation-delay: .5s; color: var(--magenta); }
  .chip-2 { bottom: 14%; right: -10px; animation-delay: 1s; color: var(--blue); }
  .chip-3 { top: 46%; right: -40px; animation-delay: 1.8s; color: var(--orange); }
  @keyframes float-chip {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }

  /* TRUST BAR */
  #trust {
    background: var(--navy);
    color: var(--white);
    padding: 28px 0;
  }
  .trust-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: .95rem;
  }

  /* WHY US */
  #de-ce-noi {
    padding: 100px 0;
    background: linear-gradient(135deg, var(--navy) 0%, #1F3056 100%);
    color: var(--white);
    position: relative;
    overflow: hidden;
  }
  #de-ce-noi::before {
    content: '✦';
    position: absolute;
    font-size: 20rem;
    opacity: .03;
    color: var(--yellow);
    top: -60px; right: -40px;
    font-family: 'Baloo 2', sans-serif;
  }
  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
