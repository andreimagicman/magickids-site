  }
  .num-card:nth-child(1) .big-num { color: var(--magenta); filter: brightness(1.15); }
  .num-card:nth-child(2) .big-num { color: var(--yellow); }
  .num-card:nth-child(3) .big-num { color: var(--blue); filter: brightness(1.2); }
  .num-card:nth-child(4) .big-num { color: var(--orange); }
